# SandCastle demo — generated by VHS (https://github.com/charmbracelet/vhs)
# Run: vhs demo.tape
#
# Opening frame shows a DENY from the sandbox.
# Sequence: install hint -> run with profile -> blocked action visible.

Output docs/demo.gif

Set Theme "Catppuccin Mocha"
Set FontFamily "JetBrains Mono"
Set FontSize 14
Set Width 1000
Set Height 560
Set TypingSpeed 45ms
Set Padding 20

# Frame 1 — opening: the agent is already running and the sandbox just blocked an action.
# No prompt, no comment first. The viewer sees the win immediately.
Type "sandcastle run --profile claude-code -- claude"
Enter
Sleep 2.5s

# While claude is booting, the sandbox surfaces a denied action.
Type "[SandCastle] DENY: read ~/.ssh/id_rsa  (policy: develop, fs.deny=~/.ssh)"
Enter
Sleep 800ms
Type "[SandCastle] DENY: connect evil-c2.example:443  (policy: develop, net.deny_by_default=true)"
Enter
Sleep 1.5s

# Frame 2 — show the install hint, then a second run.
Type "# install in 10 seconds:"
Enter
Sleep 400ms
Type "cargo install sandcastle"
Enter
Sleep 1.2s

# Frame 3 — re-run with audit mode so the viewer sees the same actions but logged, not blocked.
Type "# same run, audit-only mode (observe first, enforce later):"
Enter
Sleep 400ms
Type "sandcastle run --mode=audit --profile claude-code -- claude"
Enter
Sleep 2s

# Frame 4 — view the audit trail of what the agent tried to do.
Type "sandcastle audit violations"
Enter
Sleep 2s